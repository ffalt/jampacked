{
  "name": "jam",
  "version": "0.0.9",
  "private": true,
  "scripts": {
    "android": "react-native run-android && react-native log-android",
    "android:release": "react-native run-android --mode release && react-native log-android",
    "android:log": "react-native log-android",
    "android:build:release:apk": "cd android && ./gradlew assembleRelease",
    "android:build:release:aab": "cd android && ./gradlew bundleRelease",
    "start": "react-native start",
    "lint": "eslint .",
    "test": "jest",
    "check": "qlty check --all",
    "release": "npx commit-and-tag-version",
    "changelog:start": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 1",
    "releaselog": "node .github/scripts/extract-release.mjs",
    "logos": "react-native generate-bootsplash src/assets/images/logo.png --background=0b1821 --logo-width=100 --assets-output=assets",
    "clean:yarn": "rm -Rf node_modules && yarn install",
    "clean:gradle": "cd android && rm -Rf .gradle && rm -Rf .kotlin && rm -Rf app/build && ./gradlew clean",
    "clean": "yarn clean:yarn && yarn clean:gradle",
    "reinstall:player": "yarn remove react-native-track-player && yarn add ../react-native-track-player/",
    "codegen": "graphql-codegen --config codegen.ts -v",
    "postinstall": "patch-package"
  },
